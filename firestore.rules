rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "barvicreations@gmail.com"
      );
    }

    function isStudent(studentId) {
      return isSignedIn() && (
        // Allow if the user's UID is recorded as the guardianId for this student
        get(/databases/$(database)/documents/students/$(studentId)).data.guardianId == request.auth.uid
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Students Collection ---
    match /students/{studentId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.guardianId == request.auth.uid);
      allow create: if isAdmin() && isValidStudent(request.resource.data);
      allow update: if isAdmin() && isValidStudent(request.resource.data) && (
        request.resource.data.studentId == resource.data.studentId
      );
      allow delete: if isAdmin();
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['studentId', 'name', 'fatherName']) &&
             data.studentId is string && data.name is string && data.fatherName is string;
    }

    // --- Daily Reports ---
    match /dailyReports/{reportId} {
      allow read: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.guardianId == request.auth.uid);
      allow create: if isAdmin() && isValidReport(request.resource.data);
      allow update: if isAdmin() && isValidReport(request.resource.data);
      allow delete: if isAdmin();
    }

    function isValidReport(data) {
      return data.keys().hasAll(['studentId', 'date']) &&
             data.studentId is string && data.date is string;
    }

    // --- Attendance ---
    match /attendance/{attendanceId} {
      allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.guardianId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // --- Finance ---
    match /finance/{recordId} {
      allow read, write: if isAdmin();
    }

    // --- Admins ---
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // System managed or manual via console
    }
  }
}
